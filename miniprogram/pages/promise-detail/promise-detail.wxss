/* promise-detail.wxss */
/* 约定详情页样式 */

.detail-container {
  padding-bottom: var(--spacing-xl);
}

/* 约定卡片 */
.promise-detail-card {
  position: relative;
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
}

/* 状态标签 */
.status-badge {
  position: absolute;
  top: var(--spacing-md);
  right: var(--spacing-md);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
  font-size: 24rpx;
  color: var(--text-inverse);
}

.status-pending {
  background: var(--info);
}

.status-completed {
  background: var(--success);
}

.status-overdue {
  background: var(--danger);
}

.status-reviewed {
  background: var(--text-muted);
}

/* 标题 */
.detail-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
  margin-top: var(--spacing-md);
}

/* 参与人 */
.participants {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-lg);
  padding-bottom: var(--spacing-lg);
  border-bottom: 2rpx solid var(--divider);
}

.participant {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.participant-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-round);
  background: var(--divider);
  margin-bottom: var(--spacing-xs);
}

.participant-name {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.participant-role {
  font-size: 22rpx;
  color: var(--text-muted);
}

.participant-connector {
  font-size: 48rpx;
  margin: 0 var(--spacing-lg);
}

/* 详情区域 */
.detail-section {
  margin-bottom: var(--spacing-lg);
}

.detail-row {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--spacing-md);
}

.detail-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 签名区域 */
.signature-section {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 2rpx solid var(--divider);
}

.signature-image {
  width: 100%;
  height: 200rpx;
  margin-top: var(--spacing-sm);
  background: var(--bg);
}

.signature-placeholder {
  width: 100%;
  height: 200rpx;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 28rpx;
  margin-top: var(--spacing-sm);
  border-radius: var(--radius-md);
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: var(--spacing-md);
  gap: var(--spacing-sm);
}

.action-btn {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
}

/* 状态提示 */
.status-tip {
  margin: var(--spacing-md);
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 28rpx;
}

.status-tip.success {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success);
}

.status-tip.warning {
  background: rgba(250, 173, 20, 0.1);
  color: var(--warning);
}
