/* promise-list.wxss */
/* 我的约定列表页样式 */

.list-container {
  padding-bottom: var(--spacing-xl);
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: var(--bg-white);
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 2rpx solid var(--divider);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md) 0;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.tab-item.active .tab-label {
  color: var(--primary);
  font-weight: bold;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: var(--radius-round);
}

/* 列表 */
.promise-list {
  padding: var(--spacing-md);
}

.promise-card {
  margin-bottom: var(--spacing-sm);
  padding: var(--spacing-md);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-round);
  color: var(--text-inverse);
  margin-left: var(--spacing-sm);
}

.status-pending {
  background: var(--info);
}

.status-completed {
  background: var(--success);
}

.status-overdue {
  background: var(--danger);
}

.status-reviewed {
  background: var(--text-muted);
}

.card-body {
  display: flex;
  flex-direction: column;
}

.card-info {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.card-deadline {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-bottom: var(--spacing-md);
}

.create-btn {
  padding: var(--spacing-sm) var(--spacing-xl);
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: var(--spacing-md);
  font-size: 24rpx;
  color: var(--text-muted);
}
