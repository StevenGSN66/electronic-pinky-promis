<!-- ai-chat.wxml -->
<!-- AI辅助沟通/建议页：雁小约作为AI助手，对话气泡展示 -->

<view class="container chat-container">

  <!-- 对话消息区域 -->
  <scroll-view class="chat-messages" scroll-y="true" scroll-into-view="{{'msg-' + messages[messages.length-1].id}}">
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}" class="message-wrapper {{item.role}}">
      <!-- AI头像 -->
      <view wx:if="{{item.role === 'ai'}}" class="avatar ai-avatar">
        <text>🤖</text>
      </view>

      <!-- 消息气泡 -->
      <view class="message-bubble {{item.role}}">
        <text class="message-content">{{item.content}}</text>
        <text class="message-time">{{item.time}}</text>
      </view>

      <!-- 用户头像 -->
      <view wx:if="{{item.role === 'user'}}" class="avatar user-avatar">
        <text>👤</text>
      </view>
    </view>

    <!-- AI正在输入提示 -->
    <view wx:if="{{isTyping}}" class="message-wrapper ai">
      <view class="avatar ai-avatar"><text>🤖</text></view>
      <view class="message-bubble ai typing">
        <text class="dot">...</text>
      </view>
    </view>
  </scroll-view>

  <!-- 快捷提问区 -->
  <view class="quick-questions">
    <scroll-view scroll-x="true" class="quick-scroll">
      <view class="quick-item" bindtap="quickAsk" data-question="如何让孩子更愿意遵守约定？">如何让孩子更愿意遵守约定？</view>
      <view class="quick-item" bindtap="quickAsk" data-question="约定定得太高怎么办？">约定定得太高怎么办？</view>
      <view class="quick-item" bindtap="quickAsk" data-question="孩子没有履约怎么沟通？">孩子没有履约怎么沟通？</view>
    </scroll-view>
  </view>

  <!-- 底部输入栏 -->
  <view class="input-bar">
    <view class="voice-btn" bindtap="startVoiceInput">🎤</view>
    <input class="chat-input" type="text" placeholder="向雁小约提问..." value="{{inputText}}" bindinput="onInput" confirm-type="send" bindconfirm="sendMessage"/>
    <view class="send-btn {{inputText.trim() ? '' : 'disabled'}}" bindtap="sendMessage">发送</view>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>加载中...</text>
  </view>

</view>
