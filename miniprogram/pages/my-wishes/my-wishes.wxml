<!-- my-wishes.wxml -->
<!-- 我家私密愿望墙：家庭成员可见，可转化为约定 -->

<view class="container my-wishes-container">

  <!-- 顶部说明 -->
  <view class="wall-header card">
    <text class="header-title">🏠 我家愿望墙</text>
    <text class="header-desc">这里的愿望只有家庭成员能看到，选一个愿望，一起努力实现它吧！</text>
  </view>

  <!-- 愿望列表 -->
  <view class="wish-list">
    <view wx:for="{{wishes}}" wx:key="id" class="wish-item card">
      <view class="wish-content">
        <text class="wish-title">{{item.title}}</text>
        <text class="wish-desc">{{item.description}}</text>
        <text class="wish-date">{{item.createdAt}}</text>
      </view>
      <view class="wish-actions">
        <view class="action-tag convert" bindtap="convertToPromise" data-id="{{item.id}}">转为约定</view>
        <view class="action-tag delete" bindtap="deleteWish" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{wishes.length === 0 && !loading}}" class="empty-state">
    <text class="empty-icon">🌟</text>
    <text class="empty-text">还没有愿望，快添加一个吧</text>
  </view>

  <!-- 添加愿望按钮（悬浮） -->
  <view class="fab" bindtap="showCreate">
    <text class="fab-icon">+</text>
  </view>

  <!-- 创建愿望弹窗 -->
  <view wx:if="{{showCreateModal}}" class="modal-mask">
    <view class="modal-content card">
      <text class="modal-title">添加新愿望</text>
      <input class="modal-input" placeholder="愿望标题" value="{{newWishTitle}}" bindinput="onTitleInput"/>
      <textarea class="modal-textarea" placeholder="详细描述（可选）" value="{{newWishDesc}}" bindinput="onDescInput"/>
      <view class="modal-actions">
        <view class="btn-secondary" bindtap="closeCreate">取消</view>
        <view class="btn-primary" bindtap="createWish">确定</view>
      </view>
    </view>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>加载中...</text>
  </view>

</view>
