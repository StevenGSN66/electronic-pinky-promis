/* my-wishes.wxss */
/* 我家私密愿望墙样式 */

.my-wishes-container {
  padding-bottom: 120rpx;
}

/* 顶部说明 */
.wall-header {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 愿望列表 */
.wish-list {
  padding: 0 var(--spacing-md);
}

.wish-item {
  margin-bottom: var(--spacing-sm);
  padding: var(--spacing-md);
}

.wish-content {
  margin-bottom: var(--spacing-sm);
}

.wish-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.wish-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
}

.wish-date {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
}

.wish-actions {
  display: flex;
  gap: var(--spacing-sm);
}

.action-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-round);
}

.action-tag.convert {
  color: var(--primary);
  background: rgba(74, 144, 226, 0.1);
}

.action-tag.delete {
  color: var(--danger);
  background: rgba(255, 77, 79, 0.1);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--primary);
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  z-index: 100;
}

.fab-icon {
  color: var(--text-inverse);
  font-size: 48rpx;
  font-weight: bold;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  padding: var(--spacing-lg);
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
  text-align: center;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: var(--spacing-md);
}

.modal-textarea {
  width: 100%;
  height: 160rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: var(--spacing-md);
}

.modal-actions {
  display: flex;
  gap: var(--spacing-md);
}

.modal-actions .btn-secondary,
.modal-actions .btn-primary {
  flex: 1;
  text-align: center;
}
