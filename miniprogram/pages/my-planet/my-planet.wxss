/* my-planet.wxss */
/* 我的星球页面样式 */

.planet-container {
  padding-bottom: var(--spacing-xl);
}

/* 星球主视觉 */
.planet-visual {
  margin: var(--spacing-md);
  padding: var(--spacing-xl);
  background: linear-gradient(135deg, #1a237e 0%, #3949ab 50%, #5c6bc0 100%);
  color: var(--text-inverse);
  text-align: center;
}

.planet-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: var(--spacing-lg);
}

.tree-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tree-emoji {
  font-size: 160rpx;
  margin-bottom: var(--spacing-md);
}

.tree-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80%;
}

.tree-level {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: var(--spacing-sm);
}

.exp-bar {
  width: 100%;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-round);
  overflow: hidden;
  margin-bottom: var(--spacing-xs);
}

.exp-progress {
  height: 100%;
  background: linear-gradient(90deg, #69f0ae, #00e676);
  border-radius: var(--radius-round);
  transition: width 0.5s ease;
}

.exp-text {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 核心数据 */
.stats-row {
  display: flex;
  justify-content: space-between;
  padding: 0 var(--spacing-md);
  margin-bottom: var(--spacing-lg);
  gap: var(--spacing-md);
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-sm);
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: var(--spacing-xs);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 动态区域 */
.dynamics-section {
  padding: 0 var(--spacing-md);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.section-more {
  font-size: 24rpx;
  color: var(--primary);
}

.dynamics-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.dynamic-item {
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-md);
}

.dynamic-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.dynamic-icon.complete {
  background: rgba(82, 196, 26, 0.1);
}

.dynamic-icon.levelup {
  background: rgba(245, 166, 35, 0.1);
}

.dynamic-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.dynamic-text {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.dynamic-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.empty-state {
  text-align: center;
  padding: var(--spacing-xl);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}
