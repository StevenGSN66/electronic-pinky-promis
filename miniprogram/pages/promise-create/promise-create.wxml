<!-- promise-create.wxml -->
<!-- 创建约定页：选择发起人和接受人，输入或语音输入约定，调用AI解析，展示约定卡，电子拉钩签名确认 -->

<view class="container create-container">

  <!-- 步骤1：选择参与人 -->
  <view class="step-section">
    <text class="step-title">1. 选择参与人</text>

    <!-- 发起人 -->
    <view class="person-select">
      <text class="select-label">发起人</text>
      <view class="person-list">
        <view wx:for="{{familyMembers}}" wx:key="id" class="person-item {{initiator && initiator.id === item.id ? 'selected' : ''}}" bindtap="selectPerson" data-role="initiator" data-member="{{item}}">
          <image class="person-avatar" src="{{item.avatar}}" mode="aspectFill"/>
          <text class="person-name">{{item.name}}</text>
        </view>
        <!-- 占位展示 -->
        <view wx:if="{{familyMembers.length === 0}}" class="person-placeholder">
          <text>发起人占位</text>
        </view>
      </view>
    </view>

    <!-- 接受人 -->
    <view class="person-select">
      <text class="select-label">接受人</text>
      <view class="person-list">
        <view wx:for="{{familyMembers}}" wx:key="id" class="person-item {{acceptor && acceptor.id === item.id ? 'selected' : ''}}" bindtap="selectPerson" data-role="acceptor" data-member="{{item}}">
          <image class="person-avatar" src="{{item.avatar}}" mode="aspectFill"/>
          <text class="person-name">{{item.name}}</text>
        </view>
        <view wx:if="{{familyMembers.length === 0}}" class="person-placeholder">
          <text>接受人占位</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 步骤2：输入约定内容 -->
  <view class="step-section">
    <text class="step-title">2. 输入约定内容</text>

    <!-- 模式切换 -->
    <view class="mode-switch">
      <view class="mode-item {{inputMode === 'text' ? 'active' : ''}}" bindtap="switchMode" data-mode="text">文字输入</view>
      <view class="mode-item {{inputMode === 'voice' ? 'active' : ''}}" bindtap="switchMode" data-mode="voice">语音输入</view>
    </view>

    <!-- 文字输入 -->
    <view wx:if="{{inputMode === 'text'}}" class="input-area">
      <textarea class="content-textarea" placeholder="例如：每天晚上9点前完成作业，周末可以玩1小时游戏" value="{{content}}" bindinput="onInputContent"/>
    </view>

    <!-- 语音输入 -->
    <view wx:if="{{inputMode === 'voice'}}" class="voice-area">
      <view class="voice-btn" bindtap="startVoiceInput">
        <text class="voice-icon">🎤</text>
        <text class="voice-hint">按住说话</text>
      </view>
    </view>

    <!-- AI解析按钮 -->
    <view class="btn-primary parse-btn {{isParsing ? 'disabled' : ''}}" bindtap="parseWithAI">
      {{isParsing ? 'AI解析中...' : 'AI帮我整理约定'}}
    </view>
  </view>

  <!-- 步骤3：约定卡确认（解析完成后显示） -->
  <view wx:if="{{showConfirm && parsedPromise}}" class="confirm-panel">
    <text class="step-title">3. 确认约定内容</text>

    <view class="promise-card card">
      <text class="card-title">{{parsedPromise.title || '未命名约定'}}</text>
      <view class="card-row">
        <text class="card-label">约定内容</text>
        <text class="card-value">{{parsedPromise.content}}</text>
      </view>
      <view class="card-row">
        <text class="card-label">截止时间</text>
        <text class="card-value">{{parsedPromise.deadline}}</text>
      </view>
      <view class="card-row">
        <text class="card-label">完成标准</text>
        <text class="card-value">{{parsedPromise.standard}}</text>
      </view>
      <view class="edit-hint" bindtap="editParsedField">点击字段可编辑</view>
    </view>

    <!-- 电子拉钩签名区 -->
    <view class="signature-section">
      <text class="step-title">4. 电子拉钩</text>
      <view class="signature-pad card">
        <text class="signature-hint">在此区域手写签名确认</text>
        <!-- TODO: 引入签名组件 -->
        <view class="signature-placeholder">签名板占位</view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="btn-secondary" bindtap="goBackEdit">返回修改</view>
      <view class="btn-primary" bindtap="confirmCreate">确认创建</view>
    </view>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>处理中...</text>
  </view>

</view>
