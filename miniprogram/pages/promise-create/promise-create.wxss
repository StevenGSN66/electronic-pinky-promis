/* promise-create.wxss */
/* 创建约定页样式 */

.create-container {
  padding-bottom: var(--spacing-xl);
}

/* 步骤区块 */
.step-section {
  margin-bottom: var(--spacing-lg);
  padding: 0 var(--spacing-md);
}

.step-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

/* 人员选择 */
.person-select {
  margin-bottom: var(--spacing-md);
}

.select-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
}

.person-list {
  display: flex;
  flex-wrap: wrap;
}

.person-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  padding: var(--spacing-sm);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
}

.person-item.selected {
  border-color: var(--primary);
  background: rgba(74, 144, 226, 0.1);
}

.person-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-round);
  background: var(--divider);
  margin-bottom: var(--spacing-xs);
}

.person-name {
  font-size: 26rpx;
  color: var(--text-primary);
}

.person-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-round);
  background: var(--divider);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 模式切换 */
.mode-switch {
  display: flex;
  background: var(--bg-white);
  border-radius: var(--radius-round);
  padding: 4rpx;
  margin-bottom: var(--spacing-md);
  border: 2rpx solid var(--border);
}

.mode-item {
  flex: 1;
  text-align: center;
  padding: var(--spacing-sm);
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-round);
}

.mode-item.active {
  background: var(--primary);
  color: var(--text-inverse);
}

/* 输入区域 */
.input-area {
  margin-bottom: var(--spacing-md);
}

.content-textarea {
  width: 100%;
  height: 200rpx;
  background: var(--bg-white);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-sizing: border-box;
  font-size: 28rpx;
}

/* 语音区域 */
.voice-area {
  display: flex;
  justify-content: center;
  margin-bottom: var(--spacing-md);
}

.voice-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-round);
  background: var(--primary-light);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.voice-icon {
  font-size: 64rpx;
  margin-bottom: var(--spacing-xs);
}

.voice-hint {
  font-size: 26rpx;
  color: var(--text-inverse);
}

/* AI解析按钮 */
.parse-btn {
  width: 100%;
  text-align: center;
}

/* 确认面板 */
.confirm-panel {
  padding: 0 var(--spacing-md);
}

/* 约定卡片 */
.promise-card {
  margin-bottom: var(--spacing-lg);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: var(--spacing-md);
  text-align: center;
}

.card-row {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--spacing-sm);
  padding-bottom: var(--spacing-sm);
  border-bottom: 2rpx solid var(--divider);
}

.card-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.card-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.edit-hint {
  font-size: 24rpx;
  color: var(--primary);
  text-align: center;
  margin-top: var(--spacing-sm);
}

/* 签名区域 */
.signature-section {
  margin-bottom: var(--spacing-lg);
}

.signature-pad {
  height: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--border);
}

.signature-hint {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: var(--spacing-sm);
}

.signature-placeholder {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  gap: var(--spacing-md);
}

.action-buttons .btn-secondary,
.action-buttons .btn-primary {
  flex: 1;
  text-align: center;
}
