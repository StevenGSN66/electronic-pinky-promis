/* wish-detail.wxss */
/* 单个热门愿望详情页样式 */

.wish-detail-container {
  padding-bottom: 160rpx;
}

/* 愿望详情卡片 */
.wish-detail-card {
  margin: var(--spacing-md);
  padding: 0;
  overflow: hidden;
}

.detail-image-wrapper {
  width: 100%;
  height: 400rpx;
  background: var(--bg);
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.placeholder-emoji {
  font-size: 120rpx;
}

.detail-content {
  padding: var(--spacing-lg);
}

.detail-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.detail-meta {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.meta-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: rgba(74, 144, 226, 0.1);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-round);
  margin-right: var(--spacing-sm);
}

.meta-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.detail-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 参与用户 */
.participants-section {
  margin: var(--spacing-md);
  padding: var(--spacing-md);
}

.participants-section .section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.participant-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.participant-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.participant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  background: var(--divider);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: var(--spacing-xs);
}

.participant-nickname {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: var(--spacing-md);
  background: var(--bg-white);
  border-top: 2rpx solid var(--divider);
  gap: var(--spacing-md);
}

.action-btn {
  flex: 1;
  text-align: center;
}
