<!-- wish-detail.wxml -->
<!-- 单个热门愿望详情页：展示详情+参与用户脱敏列表+我也想许愿按钮 -->

<view class="container wish-detail-container">

  <!-- 愿望详情卡片 -->
  <view wx:if="{{wish}}" class="wish-detail-card card">
    <!-- 愿望图片 -->
    <view class="detail-image-wrapper">
      <image wx:if="{{wish.image}}" class="detail-image" src="{{wish.image}}" mode="aspectFill"/>
      <view wx:else class="detail-image-placeholder">
        <text class="placeholder-emoji">✈️</text>
      </view>
    </view>

    <!-- 愿望信息 -->
    <view class="detail-content">
      <text class="detail-title">{{wish.title}}</text>
      <view class="detail-meta">
        <text class="meta-tag">{{wish.category}}</text>
        <text class="meta-count">{{wish.participants}} 人想实现</text>
      </view>
      <text class="detail-desc">{{wish.description}}</text>
    </view>
  </view>

  <!-- 参与用户列表（脱敏） -->
  <view class="participants-section card">
    <text class="section-title">也想实现这个愿望的人</text>
    <view class="participant-list">
      <view wx:for="{{participants}}" wx:key="index" class="participant-item">
        <view class="participant-avatar">
          <text>👤</text>
        </view>
        <text class="participant-nickname">{{item.nickname}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-actions">
    <view wx:if="{{!hasJoined}}" class="btn-primary action-btn" bindtap="joinWish">加入愿望</view>
    <view wx:else class="btn-secondary action-btn disabled">已加入</view>
    <view class="btn-primary action-btn" bindtap="goToMakeWish">我也想许愿</view>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>加载中...</text>
  </view>

</view>
