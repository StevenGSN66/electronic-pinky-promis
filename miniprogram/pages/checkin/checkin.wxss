/* checkin.wxss */
/* 打卡/履约记录页样式 */

.checkin-container {
  padding-bottom: var(--spacing-xl);
}

/* 约定摘要 */
.promise-summary {
  margin: var(--spacing-md);
  padding: var(--spacing-md);
}

.summary-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.summary-info {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 区块 */
.section {
  margin: var(--spacing-md);
  padding: var(--spacing-md);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.photo {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  background: var(--bg);
}

.photo-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--danger);
  color: var(--text-inverse);
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
}

.add-icon {
  font-size: 48rpx;
  margin-bottom: var(--spacing-xs);
}

.add-hint {
  font-size: 24rpx;
}

/* 备注输入 */
.remark-textarea {
  width: 100%;
  height: 200rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-sizing: border-box;
  font-size: 28rpx;
}

/* 操作栏 */
.action-bar {
  padding: var(--spacing-md);
}

.submit-btn {
  width: 100%;
  text-align: center;
}

/* 确认区域 */
.confirm-section {
  margin: var(--spacing-md);
  padding: var(--spacing-md);
  text-align: center;
}

.confirm-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.confirm-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}
