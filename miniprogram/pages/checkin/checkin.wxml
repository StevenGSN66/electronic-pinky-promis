<!-- checkin.wxml -->
<!-- 打卡/履约记录页：记录履约情况，双方确认，上传照片/备注，完成后增加信任水滴 -->

<view class="container checkin-container">

  <!-- 约定信息摘要 -->
  <view wx:if="{{promise}}" class="promise-summary card">
    <text class="summary-title">{{promise.title}}</text>
    <text class="summary-info">完成标准：{{promise.standard}}</text>
  </view>

  <!-- 照片上传区域 -->
  <view class="section card">
    <text class="section-title">上传履约照片（可选）</text>
    <view class="photo-grid">
      <!-- 已上传的照片 -->
      <view wx:for="{{photos}}" wx:key="index" class="photo-item">
        <image class="photo" src="{{item}}" mode="aspectFill"/>
        <view class="photo-remove" bindtap="removePhoto" data-index="{{index}}">×</view>
      </view>
      <!-- 添加照片按钮 -->
      <view class="photo-add" bindtap="choosePhoto">
        <text class="add-icon">+</text>
        <text class="add-hint">添加照片</text>
      </view>
    </view>
  </view>

  <!-- 备注输入区域 -->
  <view class="section card">
    <text class="section-title">备注（可选）</text>
    <textarea class="remark-textarea" placeholder="记录一下履约情况吧，比如完成的感受、遇到的问题等" value="{{remark}}" bindinput="onInputRemark"/>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="btn-primary submit-btn {{photos.length === 0 && !remark ? 'disabled' : ''}}" bindtap="submitCheckin">
      提交打卡
    </view>
  </view>

  <!-- 对方确认区域（如已提交，等待对方确认） -->
  <view wx:if="{{!isConfirmed}}" class="confirm-section card">
    <text class="confirm-title">等待对方确认</text>
    <text class="confirm-desc">对方确认后，双方信任水滴将增加</text>
  </view>
  <view wx:else class="confirm-section card">
    <text class="confirm-title">✅ 双方已确认</text>
    <text class="confirm-desc">信任水滴已增加，继续保持哦！</text>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>处理中...</text>
  </view>

</view>
