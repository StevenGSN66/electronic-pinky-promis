<!-- review.wxml -->
<!-- 未履约AI温和复盘页：孩子和家长分别填写原因，AI生成建议，选择重新约定/补充履约/取消 -->

<view class="container review-container">

  <!-- 顶部说明 -->
  <view class="review-header card">
    <text class="header-title">未履约复盘</text>
    <text class="header-desc">没关系，每一次复盘都是成长的机会。请双方坦诚地分享各自的想法，AI助手会给出温和的建议。</text>
  </view>

  <!-- 孩子填写原因 -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">👶 孩子，说说你的想法</text>
      <text class="section-subtitle">为什么没有完成约定呢？</text>
    </view>
    <textarea class="reason-textarea" placeholder="例如：作业太多了，没有时间；或者我当时想先玩一会儿..." value="{{childReason}}" bindinput="onChildInput"/>
  </view>

  <!-- 家长填写原因 -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">👨‍👩‍👧 家长，说说你的观察</text>
      <text class="section-subtitle">你如何看待这次未履约？</text>
    </view>
    <textarea class="reason-textarea" placeholder="例如：我观察到孩子最近比较累；或者我们的约定可能定得太高了..." value="{{parentReason}}" bindinput="onParentInput"/>
  </view>

  <!-- AI生成建议按钮 -->
  <view class="btn-primary ai-btn {{isGenerating ? 'disabled' : ''}}" bindtap="generateAIAdvice">
    {{isGenerating ? '雁小约思考中...' : '获取AI温和建议'}}
  </view>

  <!-- AI建议展示（带雁小约思考形象） -->
  <view wx:if="{{aiAdvice}}" class="advice-section card">
    <mascot-guide
      text="{{aiAdvice}}"
      mood="thinking"
      showClose="{{false}}"
    />
  </view>

  <!-- 后续决策 -->
  <view wx:if="{{aiAdvice}}" class="decision-section">
    <text class="section-title">接下来想怎么做？</text>
    <view class="decision-options">
      <view class="decision-item {{decision === 'restart' ? 'selected' : ''}}" bindtap="selectDecision" data-value="restart">
        <text class="decision-icon">🔄</text>
        <text class="decision-label">重新约定</text>
        <text class="decision-desc">调整目标后再次约定</text>
      </view>
      <view class="decision-item {{decision === 'supplement' ? 'selected' : ''}}" bindtap="selectDecision" data-value="supplement">
        <text class="decision-icon">✅</text>
        <text class="decision-label">补充履约</text>
        <text class="decision-desc">现在补做，完成约定</text>
      </view>
      <view class="decision-item {{decision === 'cancel' ? 'selected' : ''}}" bindtap="selectDecision" data-value="cancel">
        <text class="decision-icon">🚫</text>
        <text class="decision-label">取消约定</text>
        <text class="decision-desc">双方同意取消此次约定</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view wx:if="{{decision}}" class="action-bar">
    <view class="btn-primary submit-btn" bindtap="submitReview">确认并保存复盘</view>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>处理中...</text>
  </view>

</view>
