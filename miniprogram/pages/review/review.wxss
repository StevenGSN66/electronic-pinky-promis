/* review.wxss */
/* 未履约AI温和复盘页样式 */

.review-container {
  padding-bottom: var(--spacing-xl);
}

/* 顶部说明 */
.review-header {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, var(--secondary-light) 0%, var(--secondary) 100%);
  color: var(--text-inverse);
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: var(--spacing-sm);
}

.header-desc {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.95;
}

/* 区块 */
.section {
  margin: var(--spacing-md);
  padding: var(--spacing-md);
}

.section-header {
  margin-bottom: var(--spacing-md);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 原因输入 */
.reason-textarea {
  width: 100%;
  height: 180rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-sizing: border-box;
  font-size: 28rpx;
}

/* AI按钮 */
.ai-btn {
  margin: var(--spacing-md);
  text-align: center;
}

/* 建议区域 */
.advice-section {
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-left: 8rpx solid var(--primary);
}

.advice-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.advice-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-sm);
}

.advice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary);
}

.advice-content {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

/* 决策区域 */
.decision-section {
  margin: var(--spacing-md);
}

.decision-options {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-md);
}

.decision-item {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-md);
  background: var(--bg-white);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border);
}

.decision-item.selected {
  border-color: var(--primary);
  background: rgba(74, 144, 226, 0.05);
}

.decision-icon {
  font-size: 40rpx;
  margin-bottom: var(--spacing-xs);
}

.decision-label {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.decision-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 操作栏 */
.action-bar {
  padding: var(--spacing-md);
}

.submit-btn {
  width: 100%;
  text-align: center;
}
