/* onboarding.wxss */
/* 新人引导页样式 */

.onboarding-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-md);
  background: linear-gradient(180deg, var(--bg) 0%, var(--bg-white) 100%);
}

/* 步骤区块 */
.step-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 品牌区域 */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--spacing-xl);
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: var(--primary-light);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: 28rpx;
  margin-bottom: var(--spacing-md);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: var(--spacing-xs);
}

.app-slogan {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 理念卡片 */
.concept-card {
  width: 100%;
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.concept-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: var(--spacing-sm);
}

.concept-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 功能亮点 */
.features {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: var(--spacing-xl);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: var(--spacing-xs);
}

.feature-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 步骤标题 */
.step-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.step-subtitle {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-bottom: var(--spacing-xl);
}

/* 头像选择 */
.avatar-wrapper {
  background: none;
  border: none;
  padding: 0;
  margin-bottom: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-round);
  background: var(--divider);
  margin-bottom: var(--spacing-sm);
}

.avatar-hint {
  font-size: 26rpx;
  color: var(--primary);
}

/* 输入框 */
.input-group {
  width: 100%;
  margin-bottom: var(--spacing-lg);
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
}

.input {
  width: 100%;
  height: 80rpx;
  background: var(--bg-white);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  box-sizing: border-box;
  font-size: 28rpx;
}

/* 家庭成员 */
.member-list {
  width: 100%;
  margin-bottom: var(--spacing-lg);
}

.member-item {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-round);
  margin-right: var(--spacing-sm);
}

.member-name {
  font-size: 30rpx;
  color: var(--text-primary);
}

.add-member-btn {
  width: 100%;
  height: 120rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 28rpx;
}

.add-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-sm);
}

/* 按钮 */
.next-btn, .finish-btn {
  width: 80%;
  margin-top: var(--spacing-xl);
}
