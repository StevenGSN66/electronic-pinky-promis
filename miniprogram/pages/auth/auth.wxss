/* auth.wxss */
/* 登录授权页样式 */

.auth-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-md);
  background: linear-gradient(180deg, var(--bg-white) 0%, var(--bg) 100%);
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--spacing-xl);
  margin-top: 60rpx;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: var(--primary-light);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: 28rpx;
  margin-bottom: var(--spacing-md);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: var(--spacing-xs);
}

.app-slogan {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 登录说明 */
.auth-info {
  width: 100%;
  margin-bottom: var(--spacing-xl);
}

.info-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.info-icon {
  font-size: 32rpx;
  margin-right: var(--spacing-sm);
}

.info-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 按钮区域 */
.auth-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.auth-btn {
  width: 80%;
  margin-bottom: var(--spacing-md);
  border: none;
}

.auth-btn::after {
  border: none;
}

.skip-link {
  font-size: 28rpx;
  color: var(--text-muted);
  text-decoration: underline;
}

/* 协议提示 */
.agreement-tips {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}

.tips-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

.tips-link {
  font-size: 22rpx;
  color: var(--primary);
}
