<!-- wish-island.wxml -->
<!-- 愿望岛主页面：分类标签栏，热门愿望榜单，预留广告位 -->

<view class="container wish-container">

  <!-- 广告位预留区域 -->
  <view class="ad-banner">
    <text class="ad-placeholder">广告位预留区域</text>
  </view>

  <!-- 顶部操作栏 -->
  <view class="action-bar">
    <view class="btn-secondary my-wish-btn" bindtap="goToMyWishes">我家愿望墙</view>
    <view class="btn-primary make-wish-btn" bindtap="makeWish">+ 我也想许愿</view>
  </view>

  <!-- 分类标签栏 -->
  <view class="category-bar">
    <scroll-view scroll-x="true" class="category-scroll">
      <view wx:for="{{tabs}}" wx:key="key" class="category-item {{currentTab === item.key ? 'active' : ''}}" bindtap="switchTab" data-tab="{{item.key}}">
        <text class="category-label">{{item.label}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 热门愿望榜单 -->
  <view class="section-title">🔥 热门愿望榜单</view>
  <view class="wish-list">
    <view wx:for="{{hotWishes}}" wx:key="id" class="wish-card card" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="wish-image-wrapper">
        <image wx:if="{{item.image}}" class="wish-image" src="{{item.image}}" mode="aspectFill"/>
        <view wx:else class="wish-image-placeholder">
          <text>{{item.category === 'travel' ? '✈️' : item.category === 'toy' ? '🧸' : '🎁'}}</text>
        </view>
      </view>
      <view class="wish-info">
        <text class="wish-title">{{item.title}}</text>
        <text class="wish-participants">{{item.participants}} 人想实现</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{hotWishes.length === 0 && !loading}}" class="empty-state">
    <text class="empty-icon">🏝️</text>
    <text class="empty-text">该分类下暂无愿望</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && hotWishes.length > 0}}" class="load-more">
    <text>加载中...</text>
  </view>
  <view wx:if="{{!hasMore && hotWishes.length > 0}}" class="no-more">
    <text>没有更多了</text>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading && hotWishes.length === 0}}" class="loading-mask">
    <text>加载中...</text>
  </view>

</view>
