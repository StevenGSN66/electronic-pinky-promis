/* wish-island.wxss */
/* 愿望岛主页面样式 */

.wish-container {
  padding-bottom: var(--spacing-xl);
}

/* 广告位 */
.ad-banner {
  margin: var(--spacing-md);
  height: 200rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ad-placeholder {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  padding: 0 var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.my-wish-btn, .make-wish-btn {
  flex: 1;
  text-align: center;
  margin: 0 var(--spacing-xs);
}

/* 分类栏 */
.category-bar {
  margin-bottom: var(--spacing-md);
  background: var(--bg-white);
  border-bottom: 2rpx solid var(--divider);
}

.category-scroll {
  white-space: nowrap;
  padding: var(--spacing-sm) var(--spacing-md);
}

.category-item {
  display: inline-block;
  padding: var(--spacing-xs) var(--spacing-md);
  margin-right: var(--spacing-sm);
  border-radius: var(--radius-round);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.category-item.active {
  background: var(--primary);
  color: var(--text-inverse);
}

/* 区块标题 */
.section-title {
  display: block;
  padding: 0 var(--spacing-md);
  margin-bottom: var(--spacing-md);
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

/* 愿望列表 */
.wish-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 var(--spacing-md);
  gap: var(--spacing-md);
}

.wish-card {
  width: calc(50% - var(--spacing-sm));
  padding: 0;
  overflow: hidden;
}

.wish-image-wrapper {
  width: 100%;
  height: 200rpx;
  background: var(--bg);
}

.wish-image {
  width: 100%;
  height: 100%;
}

.wish-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.wish-info {
  padding: var(--spacing-sm);
}

.wish-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.wish-participants {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: var(--spacing-md);
  font-size: 24rpx;
  color: var(--text-muted);
}
