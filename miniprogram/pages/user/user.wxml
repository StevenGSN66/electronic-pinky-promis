<!-- user.wxml -->
<!-- 我的页面：管理头像/昵称/家庭成员，查看勋章/守约率/历史记录 -->

<view class="container user-container">

  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="user-profile" bindtap="editProfile">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname || '未设置昵称'}}</text>
        <text class="user-edit">点击编辑资料 ></text>
      </view>
    </view>
  </view>

  <!-- 数据统计区 -->
  <view class="stats-grid card">
    <view class="stats-item" bindtap="goToMyPlanet">
      <text class="stats-value">{{stats.completionRate}}%</text>
      <text class="stats-label">守约率</text>
    </view>
    <view class="stats-item" bindtap="goToHistory">
      <text class="stats-value">{{stats.totalPromises}}</text>
      <text class="stats-label">总约定</text>
    </view>
    <view class="stats-item">
      <text class="stats-value">{{stats.completedPromises}}</text>
      <text class="stats-label">已完成</text>
    </view>
  </view>

  <!-- 勋章展示 -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">我的勋章</text>
      <text class="section-more" bindtap="goToMyPlanet">查看全部 ></text>
    </view>
    <view class="badge-list">
      <view wx:for="{{stats.badges}}" wx:key="id" class="badge-item" bindtap="viewBadge" data-id="{{item.id}}">
        <text class="badge-icon">{{item.icon || '🏅'}}</text>
        <text class="badge-name">{{item.name || '勋章占位'}}</text>
      </view>
      <view wx:if="{{stats.badges.length === 0}}" class="badge-empty">
        <text class="empty-text">还没有勋章，快去守约获取吧！</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item card" bindtap="manageFamily">
      <text class="menu-icon">👨‍👩‍👧</text>
      <text class="menu-label">家庭成员</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item card" bindtap="goToWishIsland">
      <text class="menu-icon">🌟</text>
      <text class="menu-label">愿望岛</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item card" bindtap="goToMyPlanet">
      <text class="menu-icon">🌳</text>
      <text class="menu-label">我的星球</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item card" bindtap="contactSupport">
      <text class="menu-icon">💬</text>
      <text class="menu-label">联系客服</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <view class="btn-secondary logout-btn" bindtap="logout">退出登录</view>
  </view>

  <!-- 全局加载遮罩 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text>加载中...</text>
  </view>

</view>
