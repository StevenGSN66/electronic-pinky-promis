/* app.wxss - 全局样式文件 */

/* 定义 CSS 变量（主题色） */
page {
  --primary-green: #7CD4A8;    /* 薄荷绿 - 主色调 */
  --primary-pink: #FFB7B2;     /* 粉红 */
  --primary-orange: #FFDAC1;   /* 暖橙 */
  --primary-blue: #B5D8F7;     /* 天蓝 */
  --text-main: #333333;        /* 主文字颜色 */
  --text-sub: #666666;         /* 次要文字颜色 */
  --text-light: #999999;       /* 浅色文字 */
  --bg-gray: #F5F5F5;          /* 背景灰 */
  --white: #FFFFFF;            /* 白色 */
  --border-color: #EEEEEE;     /* 边框颜色 */
  --danger: #FF6B6B;           /* 危险/错误色 */
  --success: #7CD4A8;          /* 成功色 */
  --warning: #FFDAC1;          /* 警告色 */

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-main);
  background-color: var(--bg-gray);
  line-height: 1.6;
}

/* 全局容器 */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: var(--white);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 按钮基础样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  outline: none;
  transition: opacity 0.2s;
}

.btn:active {
  opacity: 0.8;
}

/* 主按钮 - 薄荷绿 */
.btn-primary {
  background-color: var(--primary-green);
  color: var(--white);
}

/* 粉色按钮 */
.btn-pink {
  background-color: var(--primary-pink);
  color: var(--white);
}

/* 橙色按钮 */
.btn-orange {
  background-color: var(--primary-orange);
  color: var(--text-main);
}

/* 蓝色按钮 */
.btn-blue {
  background-color: var(--primary-blue);
  color: var(--text-main);
}

/* 次要按钮 */
.btn-secondary {
  background-color: var(--bg-gray);
  color: var(--text-main);
}

/* 幽灵按钮 */
.btn-ghost {
  background-color: transparent;
  color: var(--primary-green);
  border: 2rpx solid var(--primary-green);
}

/* 小按钮 */
.btn-small {
  height: 56rpx;
  padding: 0 30rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
}

/* 禁用状态 */
.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 文字按钮 */
.text-link {
  color: var(--primary-green);
  font-size: 26rpx;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
}

.subtitle {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-main);
}

/* 描述文字 */
.desc {
  font-size: 26rpx;
  color: var(--text-sub);
}

/* 辅助文字 */
.tip {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 弹性布局工具类 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 间距工具类 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: var(--border-color);
  margin: 20rpx 0;
}

/* 隐藏 */
.hidden {
  display: none !important;
}

/* 文字对齐 */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
