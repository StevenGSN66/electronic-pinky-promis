/* components/signature-pad/signature-pad.wxss */
/* 电子签名/拉钩组件样式 */

.signature-pad {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

/* 提示文字 */
.pad-tip {
  margin-bottom: 20rpx;
  text-align: center;
}

.tip-text {
  font-size: 28rpx;
  color: #999999;
}

/* 画布区域 */
.canvas-wrapper {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.signature-canvas {
  background: #FAFAFA;
  border: 2rpx dashed #CCCCCC;
  border-radius: 16rpx;
  touch-action: none; /* 防止触摸滚动干扰签名 */
}

/* 画布操作按钮 */
.canvas-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.btn-clear {
  background: #F5F5F5;
  border: 2rpx solid #DDDDDD;
  color: #999999;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
}

.btn-clear::after {
  border: none;
}

.btn-complete {
  background: #E0E0E0;
  border: none;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  font-weight: 600;
}

.btn-complete.active {
  background: var(--primary, #7CD4A8);
}

.btn-complete::after {
  border: none;
}

/* 点击确认区域 */
.tap-wrapper {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tap-divider {
  display: flex;
  align-items: center;
  width: 100%;
  margin: 32rpx 0;
}

.tap-divider::before,
.tap-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #EEEEEE;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #CCCCCC;
}

/* 点击拉钩按钮 */
.btn-tap-confirm {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #7CD4A8 0%, #5BC49A 100%);
  border: none;
  border-radius: 24rpx;
  padding: 40rpx 80rpx;
  width: 80%;
  box-shadow: 0 8rpx 24rpx rgba(124, 212, 168, 0.35);
}

.btn-tap-confirm::after {
  border: none;
}

.tap-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.tap-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}
