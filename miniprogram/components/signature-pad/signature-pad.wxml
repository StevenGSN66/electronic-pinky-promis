<!-- components/signature-pad/signature-pad.wxml -->
<!-- 电子签名/拉钩组件：支持手写签名和点击确认 -->

<view class="signature-pad">
  <!-- 提示文字 -->
  <view class="pad-tip" wx:if="{{tipText}}">
    <text class="tip-text">{{tipText}}</text>
  </view>

  <!-- 手写签名画布（canvas 模式或 both 模式时显示） -->
  <view class="canvas-wrapper" wx:if="{{mode === 'canvas' || mode === 'both'}}">
    <canvas
      id="signature-canvas"
      type="2d"
      class="signature-canvas"
      style="width: {{canvasWidth}}rpx; height: {{canvasHeight}}rpx;"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    />

    <!-- 画布操作按钮 -->
    <view class="canvas-actions">
      <button class="btn-clear" bindtap="onClear">清空</button>
      <button
        class="btn-complete {{hasDrawn ? 'active' : ''}}"
        bindtap="onComplete"
      >完成签名</button>
    </view>
  </view>

  <!-- 点击确认按钮（tap 模式或 both 模式时显示） -->
  <view class="tap-wrapper" wx:if="{{mode === 'tap' || mode === 'both'}}">
    <view class="tap-divider" wx:if="{{mode === 'both'}}">
      <text class="divider-text">或</text>
    </view>
    <button class="btn-tap-confirm" bindtap="onTapConfirm">
      <text class="tap-icon">🤝</text>
      <text class="tap-text">点击拉钩确认</text>
    </button>
  </view>
</view>
