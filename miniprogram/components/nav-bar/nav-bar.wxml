<!-- 自定义导航栏组件 -->
<view class="nav-bar" style="background: {{backgroundColor}}; color: {{textColor}}; height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
  <view class="nav-content" style="height: 44px;">
    <!-- 左侧返回按钮 -->
    <view class="nav-left" bindtap="onBack" wx:if="{{showBack}}">
      <text class="back-icon">&lt;</text>
    </view>
    <view class="nav-left-placeholder" wx:else></view>

    <!-- 中间标题 -->
    <view class="nav-title" bindtap="onTitleTap">
      <text class="title-text">{{title}}</text>
    </view>

    <!-- 右侧按钮 -->
    <view class="nav-right" bindtap="onRightTap">
      <image wx:if="{{rightIcon}}" class="right-icon" src="{{rightIcon}}" mode="aspectFit"/>
      <text wx:if="{{rightText}}" class="right-text">{{rightText}}</text>
    </view>
  </view>
</view>
