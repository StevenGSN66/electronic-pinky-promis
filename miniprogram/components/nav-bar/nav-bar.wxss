/* 自定义导航栏组件样式 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  box-sizing: border-box;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.nav-left, .nav-left-placeholder {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 36rpx;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
  padding: 0 20rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 500;
}

.nav-right {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.right-text {
  font-size: 26rpx;
}

.right-icon {
  width: 40rpx;
  height: 40rpx;
}
