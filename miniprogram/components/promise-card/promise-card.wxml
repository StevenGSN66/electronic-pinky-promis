<!-- 约定卡片组件 -->
<view class="promise-card" bindtap="onCardTap" bindlongpress="onLongPress">
  <view class="card-header">
    <text class="card-title">{{title}}</text>
    <view class="status-tag" style="background: {{statusMap[status].color}}20; color: {{statusMap[status].color}}">
      {{statusMap[status].label}}
    </view>
  </view>
  <view class="card-body">
    <view class="deadline" wx:if="{{deadline}}">
      <text class="label">截止：</text>
      <text class="value">{{deadline}}</text>
    </view>
    <view class="creator" wx:if="{{creatorName}}">
      <text class="label">创建者：</text>
      <text class="value">{{creatorName}}</text>
    </view>
  </view>
  <view class="card-footer">
    <view class="progress-bar" bindtap="onProgressTap">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
      <text class="progress-text">{{progress}}%</text>
    </view>
  </view>
</view>
