/* 热门愿望排名卡片组件样式 */
.wish-rank-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.rank-number {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.rank-content {
  flex: 1;
  margin: 0 20rpx;
  min-width: 0;
}

.wish-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 8rpx;
}

.rank-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wish-count {
  font-size: 24rpx;
  color: #999;
}

.trend-icon {
  font-size: 24rpx;
}

.trend-icon.up {
  color: #ff4d4f;
}

.trend-icon.down {
  color: #52c41a;
}

.trend-icon.flat {
  color: #999;
}

.join-btn {
  background: #1890ff;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}
