<!-- 热门愿望排名卡片组件 -->
<view class="wish-rank-card" bindtap="onCardTap">
  <view class="rank-number" style="color: {{rank <= 3 ? rankColors[rank - 1] : '#999'}}">
    <text>{{rank}}</text>
  </view>
  <view class="rank-content">
    <text class="wish-text">{{content}}</text>
    <view class="rank-meta">
      <text class="wish-count">{{wishCount}} 人许愿</text>
      <view class="trend-icon {{trend}}">
        <text wx:if="{{trend === 'up'}}">&#8593;</text>
        <text wx:elif="{{trend === 'down'}}">&#8595;</text>
        <text wx:else>-</text>
      </view>
    </view>
  </view>
  <view class="join-btn" bindtap="onJoinTap">
    <text>+ 许愿</text>
  </view>
</view>
