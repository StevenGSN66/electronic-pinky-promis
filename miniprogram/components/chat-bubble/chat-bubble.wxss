/* AI对话气泡组件样式 */
.chat-bubble {
  display: flex;
  margin-bottom: 24rpx;
  padding: 0 20rpx;
}

.ai-bubble {
  flex-direction: row;
}

.user-bubble {
  flex-direction: row-reverse;
}

.avatar-wrap {
  flex-shrink: 0;
  margin: 0 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.bubble-content {
  max-width: 70%;
}

.bubble-body {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.ai-bubble .bubble-body {
  background: #f6ffed;
  color: #333;
  border-top-left-radius: 4rpx;
}

.user-bubble .bubble-body {
  background: #e6f7ff;
  color: #333;
  border-top-right-radius: 4rpx;
}

.bubble-text {
  display: block;
}

.bubble-text.folded {
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.expand-btn {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #1890ff;
}

.bubble-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 16rpx;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.copy-btn {
  font-size: 22rpx;
  color: #1890ff;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.loading-dots .dot {
  width: 12rpx;
  height: 12rpx;
  background: #1890ff;
  border-radius: 50%;
  animation: dotPulse 1.4s infinite ease-in-out both;
}

.loading-dots .dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dots .dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}
