<!-- 愿望分类标签栏组件 -->
<scroll-view class="category-tab" scroll-x="true" scroll-left="{{scrollLeft}}" scroll-with-animation="true">
  <view class="tab-list">
    <view wx:for="{{categories}}" wx:key="id"
          class="tab-item {{item.id === activeId ? 'active' : ''}}"
          style="{{item.id === activeId ? 'color:' + activeColor + ';border-color:' + activeColor : ''}}"
          data-id="{{item.id}}"
          data-index="{{index}}"
          bindtap="onCategoryTap">
      <text>{{item.name}}</text>
    </view>
  </view>
</scroll-view>
