<!-- 信任水滴组件 -->
<view class="water-drop {{size}}" bindtap="onDropTap">
  <view class="drop-container {{isAnimating ? 'animate' : ''}}">
    <image class="drop-icon" src="/assets/images/water-drop.png" mode="aspectFit"/>
    <text class="drop-count">{{count}}</text>
  </view>
  <view class="delta-popup {{isAnimating ? 'show' : ''}}">
    <text class="delta-text">{{displayDelta}}</text>
  </view>
</view>
