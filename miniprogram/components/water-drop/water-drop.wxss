/* 信任水滴组件样式 */
.water-drop {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.water-drop.small .drop-icon {
  width: 40rpx;
  height: 40rpx;
}

.water-drop.small .drop-count {
  font-size: 20rpx;
}

.water-drop.normal .drop-icon {
  width: 64rpx;
  height: 64rpx;
}

.water-drop.normal .drop-count {
  font-size: 28rpx;
}

.water-drop.large .drop-icon {
  width: 96rpx;
  height: 96rpx;
}

.water-drop.large .drop-count {
  font-size: 36rpx;
}

.drop-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drop-container.animate {
  animation: dropBounce 0.6s ease;
}

.drop-icon {
  filter: drop-shadow(0 2rpx 4rpx rgba(24, 144, 255, 0.3));
}

.drop-count {
  position: absolute;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.delta-popup {
  position: absolute;
  top: -40rpx;
  opacity: 0;
  transition: all 0.3s;
}

.delta-popup.show {
  animation: floatUp 1s ease forwards;
}

.delta-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #52c41a;
}

@keyframes dropBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-40rpx); }
}
