/* 愿望卡片组件样式 */
.wish-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-badge.pending {
  color: #fa8c16;
  background: #fff7e6;
}

.status-badge.fulfilled {
  color: #52c41a;
  background: #f6ffed;
}

.status-badge.expired {
  color: #999;
  background: #f5f5f5;
}

.card-body {
  margin-bottom: 20rpx;
}

.wish-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.card-footer {
  display: flex;
  gap: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.action-btn .icon {
  font-size: 28rpx;
}

.action-btn.like.active {
  color: #ff4d4f;
}
