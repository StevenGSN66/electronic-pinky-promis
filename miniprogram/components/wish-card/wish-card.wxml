<!-- 愿望卡片组件 -->
<view class="wish-card" bindtap="onCardTap">
  <view class="card-header">
    <view class="category-tag">{{categoryMap[category] || '其他'}}</view>
    <view class="status-badge {{status}}">{{status === 'fulfilled' ? '已实现' : status === 'expired' ? '已过期' : '许愿中'}}</view>
  </view>
  <view class="card-body">
    <text class="wish-content">{{content}}</text>
  </view>
  <view class="card-footer">
    <view class="action-btn like {{hasLiked ? 'active' : ''}}" bindtap="onLikeTap">
      <text class="icon">&#9829;</text>
      <text class="count">{{likes}}</text>
    </view>
    <view class="action-btn share" bindtap="onShareTap">
      <text class="icon">&#x2192;</text>
      <text>分享</text>
    </view>
  </view>
</view>
