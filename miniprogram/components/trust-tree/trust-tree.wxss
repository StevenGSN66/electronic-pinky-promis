/* 信任树组件样式 */
.trust-tree {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: #f6ffed;
  border-radius: 24rpx;
}

.tree-stage {
  font-size: 32rpx;
  font-weight: bold;
  color: #52c41a;
  margin-bottom: 24rpx;
}

.tree-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
}

.tree-progress {
  width: 100%;
  margin-bottom: 16rpx;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.drops-count {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  display: block;
}

.stage-dots {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.stage-dots .dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d9d9d9;
  transition: background 0.3s;
}

.stage-dots .dot.active {
  width: 32rpx;
  border-radius: 8rpx;
}
